OPENROUTER_API_KEY=your_openrouter_key_here
APIFY_TOKEN=your_apify_token_here
# Optional overrides:
# LLM_MODEL=google/gemma-2-9b-it:free
# LLM_FALLBACK_MODELS=meta-llama/llama-3.1-8b-instruct:free,mistralai/mistral-7b-instruct:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# APP_NAME=CrowdWisdomTrading-Prediction-Agent
# BINANCE_BASE_URL=https://api.binance.com
# KLINE_INTERVAL=5m
# KLINE_LIMIT=1000
# SYMBOLS=BTCUSDT,ETHUSDT
# KELLY_FRACTION=0.25
# MAX_KELLY_STAKE=0.05
# FEEDBACK_STORE_PATH=data/feedback.json
# LOG_LEVEL=INFO
# LOG_FILE_PATH=logs/crown.log
# ENABLE_APIFY=true
# APIFY_POLYMARKET_ACTOR_ID=your_actor_id
# APIFY_KALSHI_ACTOR_ID=your_actor_id
# APIFY_TIMEOUT_S=45
# ENABLE_KRONOS=true
# KRONOS_REPO_PATH=C:/path/to/Kronos
# ENABLE_LLM_REASONING=true
# STRICT_INTEGRATIONS=false
